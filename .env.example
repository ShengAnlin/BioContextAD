# BioContextAD — API Key Configuration
# Copy this file to .env and fill in your keys
# Leave unused roles empty — they will be skipped automatically

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen (via DashScope)
DASHSCOPE_API_KEY=

# Baichuan
BAICHUAN_API_KEY=

# Kimi (Moonshot)
MOONSHOT_API_KEY=

# Default model roles (override in configs/models.yaml)
MODEL_ROUTER=deepseek-chat
MODEL_RAG=claude-sonnet-4-6
MODEL_ABSTENTION=claude-sonnet-4-6
MODEL_TEACHER_1=claude-sonnet-4-6
MODEL_TEACHER_2=gpt-4.1
MODEL_TEACHER_3=baichuan-m3-turbo
MODEL_REPORT=moonshot-v1-32k
